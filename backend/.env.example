# =====================
# Server Configuration
# =====================
# Port the backend server runs on
PORT=5000
# Environment: development | production
NODE_ENV=development

# =====================
# Database (MongoDB Atlas)
# =====================
# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://aqibkha9x:DkyucQ2Ccjs4EwHD@cluster0.skvdstf.mongodb.net/charcha?retryWrites=true&w=majority

# =====================
# AI Layer (Google Gemini)
# =====================
# Get from https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here
# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# =====================
# Authentication (JWT)
# =====================
# Secret key for signing JWT tokens (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this
# Token expiry duration
JWT_EXPIRES_IN=7d

# =====================
# CORS / Frontend
# =====================
# Frontend URL for CORS (Firebase Hosting URL in production)
CLIENT_URL=http://localhost:8080

# =====================
# Business Logic Config
# =====================
# Radius (in meters) for duplicate issue detection
DUPLICATE_RADIUS_METERS=50
# Max file upload size in MB
MAX_FILE_SIZE_MB=10

# =====================
# Governance & Trust
# =====================
# Days before an unresolved issue auto-escalates (doc §5.1.11.4)
ESCALATION_THRESHOLD_DAYS=7
# Trust score at/below which a citizen is exempt from the daily report cap
HIGH_TRUST_THRESHOLD=75
# Max reports a low-trust citizen can file per day
DAILY_REPORT_LIMIT=3
# Directory where uploaded images are stored (relative to backend root)
UPLOAD_DIR=uploads
